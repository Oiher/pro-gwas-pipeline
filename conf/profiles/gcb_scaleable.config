/*
 * GCB_SCALEABLE profile - same as gcb_final, but maxForks for the high-fan-out processes
 * scale from params.gcb_ssd_quota_gb / params.gcb_cpu_quota instead of being hardcoded for
 * gcb_final's tuned 500GB SSD / 200 CPU baseline. Use this if your GCP project/region has a
 * different regional quota. See bin/detect_gcp_quota.sh to look up your actual quota, and
 * README.md for usage.
 */

includeConfig 'gcb_final.config'

params {
    // Regional quota gcb_final.config's maxForks values were tuned against -- override these
    // to your project's actual quota (run bin/detect_gcp_quota.sh to find it).
    gcb_ssd_quota_gb = 500
    gcb_cpu_quota    = 200
}

// Scale factor relative to the 500GB/200CPU baseline; whichever resource is proportionally
// scarcer caps the scale-up. User-defined functions aren't usable in nextflow.config's DSL
// (confirmed empirically -- "Unknown method invocation" errors), so each process's maxForks
// is computed inline as a top-level def rather than via a shared helper function.
def gcbScale = Math.min(params.gcb_ssd_quota_gb / 500.0, params.gcb_cpu_quota / 200.0)

// Baseline maxForks values below are gcb_final.config's proven-safe ones (see that file) --
// only maxForks is recomputed here; disk/cpus/memory/time are inherited unchanged, since
// Nextflow merges same-named withName blocks directive-by-directive, not wholesale.
def rawfileExportForks = Math.max(1, Math.floor(2 * gcbScale) as int)
def splitVcfForks      = Math.max(1, Math.floor(4 * gcbScale) as int)
def ldPruneChrForks    = Math.max(1, Math.floor(4 * gcbScale) as int)
def gwascphForks       = Math.max(1, Math.floor(8 * gcbScale) as int)
def geneticqcForks     = Math.max(1, Math.floor(5 * gcbScale) as int)
def gwasgallopForks    = Math.max(1, Math.floor(6 * gcbScale) as int)
def gwasglmForks       = Math.max(1, Math.floor(4 * gcbScale) as int)
def geneticqcplinkForks = Math.max(1, Math.floor(4 * gcbScale) as int)

process {
    withName: 'RAWFILE_EXPORT'  { maxForks = rawfileExportForks }
    withName: 'SPLIT_VCF'       { maxForks = splitVcfForks }
    withName: 'LD_PRUNE_CHR'    { maxForks = ldPruneChrForks }
    withName: 'GWASCPH'         { maxForks = gwascphForks }
    withName: 'GENETICQC'       { maxForks = geneticqcForks }
    withName: 'GWASGALLOP'      { maxForks = gwasgallopForks }
    withName: 'GWASGLM'         { maxForks = gwasglmForks }
    withName: 'GENETICQCPLINK'  { maxForks = geneticqcplinkForks }
}
