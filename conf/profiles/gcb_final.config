/*
 * GCB_FINAL profile - Google Cloud Batch configuration
 * Unifies the old gcb.config (Verily Workbench) and gcb2.config (gp2-release-terra).
 * Container image and private-address behavior are params (see conf/params.config).
 * network/subnetwork are hardcoded from gcb.config -- unconfirmed if safe for all VWB workspaces.
 */

workDir = "${params.project_dir}/work"
cleanup = false

process {
    executor = 'google-batch'
    container = params.gcb_container
    // Retry on transient Batch errors, preemption (143), and lost tasks (null exit).
    errorStrategy = { task.exitStatus in [14, 143, 104] || task.exitStatus == null ? 'retry' : 'terminate' }
    maxRetries = 5

    beforeScript = '''
        echo "=== Task Environment ===" >&2
        echo "Task started: $(date)" >&2
        echo "Hostname: $(hostname)" >&2
        echo "CPUs: $(nproc)" >&2
        echo "Memory: $(free -h | awk '/^Mem:/ {print $7 " available of " $2}')" >&2
        echo "Disk: $(df -h . | tail -1 | awk '{print $4 " available of " $2}')" >&2
        echo "======================" >&2
    '''.stripIndent()

    afterScript = '''
        EXIT_CODE=$?
        echo "=== Task Completion ===" >&2
        echo "Task finished: $(date)" >&2
        echo "Exit code: $EXIT_CODE" >&2
        echo "Memory used: $(free -h | awk '/^Mem:/ {print $3}')" >&2
        echo "======================" >&2
        exit $EXIT_CODE
    '''.stripIndent()

    // Most processes on these labels handle small, bounded I/O; outliers get their own
    // withName override below.
    withLabel: small {
        cpus = 2
        memory = '4 GB'
        time = '2h'
        disk = '20 GB'
    }

    withLabel: medium {
        cpus = 4
        memory = '8 GB'
        time = '4h'
        disk = '30 GB'
    }

    // Used by full-genome merge steps (MERGER_CHUNKS, MERGER_CHRS).
    withLabel: large {
        cpus = 8
        memory = '16 GB'
        time = '8h'
        disk = '200 GB'
    }

    // COMPUTE_PCA shares label 'large' for cpu/mem but fans out per study arm, so it gets a
    // smaller disk override than MERGER_CHUNKS/MERGER_CHRS need.
    withName: 'COMPUTE_PCA' {
        cpus = 8
        memory = '16 GB'
        time = '8h'
        disk = '100 GB'
    }

    // Used by GWASQC (genome-wide ancestry/kinship/PCA in one task).
    withLabel: very_large {
        cpus = 16
        memory = '256 GB'
        time = '12h'
        disk = '200 GB'
    }

    withLabel: two_cpu_large_mem {
        cpus = 2
        memory = '128 GB'
        time = '2h'
        disk = '200 GB'
    }

    // ==========================================================================
    // Per-process overrides for outliers that don't fit their label's baseline.
    // ==========================================================================

    // ---- small-label outliers ----
    withName: 'RAWFILE_EXPORT' {
        cpus = 2
        memory = '4 GB'
        time = '2h'
        // ASCII dosage export can exceed source pfile size; disk kept at the old default.
        disk = '100 GB'
        maxForks = 4
    }
    withName: 'SPLIT_VCF' {
        cpus = 2
        memory = '4 GB'
        time = '2h'
        // Holds the original VCF plus all its chunks at once.
        disk = '70 GB'
        maxForks = 4
    }
    withName: 'LD_PRUNE_CHR' {
        cpus = 2
        memory = '4 GB'
        time = '2h'
        // One whole per-chromosome pfile in/out.
        disk = '50 GB'
        maxForks = 4
    }
    withName: 'GWASCPH' {
        cpus = 2
        memory = '4 GB'
        time = '2h'
        // Bounded chunked input, but fans out per (chunk x phenotype).
        disk = '20 GB'
        maxForks = 8
    }

    // ---- medium-label outliers ----
    withName: 'GENETICQC' {
        cpus = 4
        memory = '8 GB'
        time = '4h'
        // Highest-concurrency process: one task per ~30k-variant chunk.
        disk = '60 GB'
        maxForks = 5
    }
    withName: 'GWASGALLOP' {
        cpus = 4
        memory = '8 GB'
        time = '4h'
        // Same shape as GWASCPH: bounded chunk input, fans out per (chunk x phenotype).
        disk = '30 GB'
        maxForks = 8
    }
    withName: 'GWASGLM' {
        cpus = 4
        memory = '8 GB'
        time = '4h'
        // One whole per-chromosome pfile, multi-phenotype output.
        disk = '45 GB'
        maxForks = 4
    }

    // Same full-genome-merged-pfile scale as GWASQC; was under-provisioned at the medium baseline.
    withName: 'SIMPLE_QC' {
        cpus = 4
        memory = '8 GB'
        time = '4h'
        disk = '150 GB'
    }

    // One task per chromosome. Memory bumped from two_cpu_large_mem's 128GB/2cpu (an
    // unsatisfiable ratio on real GCP machines) to a real 4GB/vCPU ratio, plus a fan-out cap.
    withName: 'GENETICQCPLINK' {
        cpus = 8
        memory = '32 GB'
        time = '2h'
        disk = '100 GB'
        maxForks = 4
    }
}

executor {
    queueSize = 200
    submitRateLimit = '10 sec'
}

// Inert under executor='google-batch' -- Batch runs containers via its own API, not
// Nextflow's docker/singularity wrapper. Left in place for parity with the old configs.
singularity {
    enabled = true
    autoMounts = true
    cacheDir = '/work/users/$USER/singularity_cache'
}

google {
    region = 'europe-west4'
    location = 'europe-west4'
    project = "${GOOGLE_CLOUD_PROJECT}"
    batch.serviceAccountEmail = "${GOOGLE_SERVICE_ACCOUNT_EMAIL}"
    batch.usePrivateAddress = params.gcb_use_private_address
    batch.network = 'global/networks/network'
    batch.subnetwork = "regions/europe-west4/subnetworks/subnetwork"
    batch.bootDiskSize = '100 GB'
    batch.allowedLocations = ['zones/europe-west4-a', 'zones/europe-west4-b']
}
