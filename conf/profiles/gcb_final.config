/*
 * GCB_FINAL profile - Google Cloud Batch configuration
 *
 * Unifies what used to be two near-duplicate profiles:
 *   - gcb.config  (Verily Workbench, ghcr.io image, private-IP-only VMs)
 *   - gcb2.config (gp2-release-terra, Artifact Registry image, public-IP VMs, broader retry policy)
 * The two differed only in container image, usePrivateAddress, and retry robustness.
 * Container image and private-address behavior are now params (see conf/params.config,
 * "Google Cloud Batch" section) -- override them via -params-file for a non-VWB project, e.g.:
 *   gcb_container: 'europe-west4-docker.pkg.dev/gp2-release-terra/long-gwas/long-gwas:latest'
 *   gcb_use_private_address: false
 * Retry policy and disk sizing below use the more robust settings from the old gcb2.config.
 *
 * network/subnetwork are still hardcoded (carried over as-is from gcb.config) -- see the
 * project discussion on whether these need to become params too before relying on this
 * for a workspace that isn't known to provision a VPC/subnet literally named "network"/"subnetwork".
 */

workDir = "${params.project_dir}/work"
cleanup = false

process {
    executor = 'google-batch'
    container = params.gcb_container
    // Retry on: 14 (transient Batch error), 143 (SIGTERM, e.g. preemption), 104 (connection reset),
    // or null (task lost/killed abnormally with no exit code reported).
    errorStrategy = { task.exitStatus in [14, 143, 104] || task.exitStatus == null ? 'retry' : 'terminate' }
    maxRetries = 5

    beforeScript = '''
        echo "=== Task Environment ===" >&2
        echo "Task started: $(date)" >&2
        echo "Hostname: $(hostname)" >&2
        echo "CPUs: $(nproc)" >&2
        echo "Memory: $(free -h | awk '/^Mem:/ {print $7 " available of " $2}')" >&2
        echo "Disk: $(df -h . | tail -1 | awk '{print $4 " available of " $2}')" >&2
        echo "======================" >&2
    '''.stripIndent()

    afterScript = '''
        EXIT_CODE=$?
        echo "=== Task Completion ===" >&2
        echo "Task finished: $(date)" >&2
        echo "Exit code: $EXIT_CODE" >&2
        echo "Memory used: $(free -h | awk '/^Mem:/ {print $3}')" >&2
        echo "======================" >&2
        exit $EXIT_CODE
    '''.stripIndent()

    // small/medium: most processes in these labels handle bounded, per-sample/per-chunk
    // tabular I/O (see the withName overrides below for the outliers that don't). Disk
    // sized well below the old 100 GB global-default fallback since these are also the
    // highest-concurrency processes in the pipeline -- the biggest single lever on
    // worst-case concurrent SSD_TOTAL_GB usage.
    withLabel: small {
        cpus = 2
        memory = '4 GB'
        time = '2h'
        disk = '20 GB'
    }

    withLabel: medium {
        cpus = 4
        memory = '8 GB'
        time = '4h'
        disk = '30 GB'
    }

    // large: used by full-genome merge/aggregation steps (MERGER_CHUNKS, MERGER_CHRS). These
    // handle merged multi-chromosome data and have run into the 50 GB global boot disk default
    // in practice -- sized explicitly here. See the COMPUTE_PCA withName override below for why
    // that process, despite sharing this label, doesn't inherit this disk size.
    withLabel: large {
        cpus = 8
        memory = '16 GB'
        time = '8h'
        disk = '200 GB'
    }

    // COMPUTE_PCA also carries label 'large' (for CPU/mem parity -- it still runs plink2 --pca
    // over the full merged genome-wide pfile), but it fans out one task per study arm
    // (modules/dataprep.nf, `each path(samplelist)`), so concurrent instances each provision
    // their own boot disk -- N study arms x 200 GB was a major contributor to hitting the
    // project's SSD_TOTAL_GB regional quota (Batch boot disks are pd-balanced, which is
    // SSD-backed and counts against that quota). 100 GB keeps meaningful headroom over the
    // original 50 GB default while halving this process's contribution to concurrent SSD usage.
    // Tune down further (or raise executor.queueSize limits) if quota errors persist; tune up
    // if a large cohort's merged pfile plus per-arm scratch genuinely needs more.
    withName: 'COMPUTE_PCA' {
        cpus = 8
        memory = '16 GB'
        time = '8h'
        disk = '100 GB'
    }

    // very_large: currently used by GWASQC (genome-wide ancestry/kinship/PCA on the full merged
    // cohort in one task -- see modules/qc.nf). Given explicit disk sizing to match
    // two_cpu_large_mem rather than falling back to the smaller global default.
    withLabel: very_large {
        cpus = 16
        memory = '256 GB'
        time = '12h'
        disk = '200 GB'
    }

    withLabel: two_cpu_large_mem {
        cpus = 2
        memory = '128 GB'
        time = '2h'
        disk = '200 GB'
    }

    // ==========================================================================
    // small/medium disk right-sizing: the label baselines above were lowered from
    // the 100 GB global default because most small/medium processes handle bounded,
    // per-sample/per-chunk tabular data. The processes below handle whole
    // VCF/pfile/chromosome-scale data and need more than the new baseline --
    // overridden individually, same withName-over-withLabel pattern as COMPUTE_PCA
    // above. Ordered by originating label.
    // ==========================================================================

    // ---- small-label outliers ----
    withName: 'RAWFILE_EXPORT' {
        cpus = 2
        memory = '4 GB'
        time = '2h'
        // unchanged from the old 100 GB default: ASCII dosage export can exceed the
        // source pfile size, and all chunked .raw outputs are declared process
        // outputs that must coexist at task completion -- not safely cuttable
        // without a script redesign (see modules/dataprep.nf).
        disk = '100 GB'
    }
    withName: 'SPLIT_VCF' {
        cpus = 2
        memory = '4 GB'
        time = '2h'
        // holds the whole original per-chromosome VCF plus all resulting chunks
        // simultaneously (modules/qc.nf, `scratch true`).
        disk = '70 GB'
        // concurrency backstop: even right-sized, high fan-out here (one task per
        // chromosome/contig, potentially per initial chunk) contributes meaningfully
        // to SSD_TOTAL_GB; caps this process's worst case near 4 x 70 GB = 280 GB.
        maxForks = 4
    }
    withName: 'LD_PRUNE_CHR' {
        cpus = 2
        memory = '4 GB'
        time = '2h'
        // one whole per-chromosome pfile in, pruned pfile out.
        disk = '35 GB'
    }

    // ---- medium-label outliers ----
    withName: 'GENETICQC' {
        cpus = 4
        memory = '8 GB'
        time = '4h'
        // stages the full original per-chromosome VCF (fOrig) into scratch for every
        // chunk task even though it's never read by the script (modules/qc.nf) --
        // dropping fOrig from the input entirely would let this drop much further;
        // tracked as a follow-up, not done here. This is the highest-concurrency
        // process in the pipeline (one task per ~30k-variant chunk).
        disk = '60 GB'
        // concurrency backstop: caps worst case near 5 x 60 GB = 300 GB.
        maxForks = 5
    }
    withName: 'GWASGLM' {
        cpus = 4
        memory = '8 GB'
        time = '4h'
        // one whole per-chromosome pfile, multi-phenotype .results output.
        disk = '45 GB'
    }

    // ---- SIMPLE_QC: disk-space-failure risk (not quota), same root cause as
    // GWASQC -- found while auditing this file for the quota fix, folded in here.
    withName: 'SIMPLE_QC' {
        cpus = 4
        memory = '8 GB'
        time = '4h'
        // full genome-wide "allchr_merged" pfile, same scale as GWASQC
        // (very_large, 200GB) -- was silently under-provisioned at the old
        // medium/100GB default and would regress further once the medium baseline
        // dropped to 30GB above. cpu/mem left at medium pending separate
        // investigation of bin/simple_qc.sh's actual compute needs.
        disk = '150 GB'
    }
}

executor {
    queueSize = 200
    submitRateLimit = '10 sec'
}

// NOTE: this block is inert under executor = 'google-batch'. Google Batch runs containers
// itself via the Batch API using the `container` value set above -- Nextflow's local
// singularity/docker wrapper logic (which is what these settings configure) never runs for
// this executor. Left here unchanged from the original gcb.config/gcb2.config for parity;
// verified no conflict/warning is emitted with executor = 'google-batch' set alongside it.
singularity {
    enabled = true
    autoMounts = true
    cacheDir = '/work/users/$USER/singularity_cache'
}

google {
    region = 'europe-west4'
    location = 'europe-west4'
    project = "${GOOGLE_CLOUD_PROJECT}"
    batch.serviceAccountEmail = "${GOOGLE_SERVICE_ACCOUNT_EMAIL}"
    batch.usePrivateAddress = params.gcb_use_private_address
    batch.network = 'global/networks/network'
    batch.subnetwork = "regions/europe-west4/subnetworks/subnetwork"
    batch.bootDiskSize = '100 GB'
    batch.allowedLocations = ['zones/europe-west4-a', 'zones/europe-west4-b']
}
