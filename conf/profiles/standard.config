/*
 * Standard profile - for typical HPC environments with SLURM/PBS
 */

// References are bind-mounted to a fixed in-container path (see containerOptions below),
// so this overrides the params.config default (which points at the host/cloud reference_dir).
// analyses_dir / genotypes_dir don't need overriding here -- they're profile-independent
// and already computed in conf/params.config.
params.container_reference_dir = "/workspace/References"

workDir = "${params.project_dir}/work"

process {
    executor = 'local'
    container = 'ghcr.io/hirotaka-i/long-gwas-pipeline:latest'
    containerOptions = "-v ${params.reference_dir}:/workspace/References --platform linux/amd64"
    
    withLabel: small {
        cpus = 2
        memory = '4 GB'
        time = '2h'
    }
    
    withLabel: medium {
        cpus = 2
        memory = '4 GB'
        time = '4h'
    }
    
    withLabel: large {
        cpus = 2
        memory = '4 GB'
        time = '6h'
    }
        
    withLabel: very_large {
        cpus = 4
        memory = '8 GB'
        time = '12h'
    }

    withLabel: two_cpu_large_mem {
        cpus = 2
        memory = '8 GB'
        time = '2h'
    }
}

docker {
    enabled = true
    temp = 'auto'
}

executor {
    queueSize = 100
    pollInterval = '30 sec'
}
