/*
 * Biowulf profile - NIH HPC cluster configuration
 */

// References are bind-mounted to a fixed in-container path (see singularity.runOptions below),
// so this overrides the params.config default (which points at the host/cloud reference_dir).
// analyses_dir / genotypes_dir don't need overriding here -- they're profile-independent
// and already computed in conf/params.config.
params.container_reference_dir = "/workspace/References"

workDir = "${params.project_dir}/work"

process {
    executor = 'slurm'
    queue = 'norm'
    clusterOptions = '--gres=lscratch:200'
    container = "${params.STORE_ROOT}/Docker/long-gwas-pipeline.sif"
    
    withLabel: small {
        cpus = 2
        memory = '8 GB'
        time = '2h'
    }
    
    withLabel: medium {
        cpus = 4
        memory = '16 GB'
        time = '4h'
    }
    
    withLabel: large {
        cpus = 8
        memory = '32 GB'
        time = '8h'
    }
    
    withLabel: very_large {
        cpus = 16
        memory = '256 GB'
        time = '12h'
    }

    withLabel: two_cpu_large_mem {
        cpus = 2
        memory = '128 GB'
        time = '2h'
    }
}

executor {
    name = 'slurm'
    pollInterval = '2 min'
    queueSize = 200
    queueStatInterval = '5 min'
    submitRateLimit = '6/1min'
}

singularity {
    enabled = true
    autoMounts = true
    cacheDir = '/data/$USER/singularity_cache'
    runOptions = "--bind ${projectDir} --bind ${params.reference_dir}:/workspace/References --bind /lscratch --env APPEND_PATH=${projectDir}/bin"
}
